{
  "name": "@talkd/pi-voice",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "keywords": ["pi-package"],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "setup:runtime": "bash ./scripts/setup-talkd-runtime.sh",
    "postinstall": "bash ./scripts/setup-talkd-runtime.sh"
  },
  "pi": {
    "extensions": ["./src/index.ts"],
    "skills": ["./skills"]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@earendil-works/pi-tui": "^0.79.8",
    "@types/bun": "latest",
    "typescript": "latest",
    "typebox": "latest"
  }
}
